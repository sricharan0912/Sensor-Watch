{
  "title": "SensorWatch — Anomaly Detection",
  "uid": "sensorwatch-anomalies",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Anomalies (last 1h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT COUNT(*) FROM anomaly_events WHERE time > NOW() - INTERVAL '1 hour' AND severity != 'NORMAL'",
        "format": "table"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Critical Anomalies (last 1h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT COUNT(*) FROM anomaly_events WHERE time > NOW() - INTERVAL '1 hour' AND severity = 'CRITICAL'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Reconstruction Error Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT time, engine_id, reconstruction_error FROM anomaly_events WHERE $__timeFilter(time) ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Sensor s4 (Fan Inlet Temp) — 1-min avg",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT bucket AS time, engine_id, s4_avg AS \"s4 avg\" FROM sensor_readings_1min WHERE $__timeFilter(bucket) ORDER BY bucket",
        "format": "time_series"
      }]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent Anomaly Events",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT time, engine_id, severity, reconstruction_error, acknowledged FROM anomaly_events WHERE severity != 'NORMAL' ORDER BY time DESC LIMIT 50",
        "format": "table"
      }]
    }
  ]
}
